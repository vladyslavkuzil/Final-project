# Application
APP_NAME=Project Dashboard API
APP_ENV=local
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Security / JWT
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=4320

# Database
POSTGRES_DB=project_dashboard
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://<user>:<password>@db:5432/<db>

# Test Database
TEST_POSTGRES_DB=project_dashboard_test
TEST_DATABASE_URL=postgresql+psycopg://<user>:<password>@db-test:5432/<test_db>

# Ports
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
